# The launcher execs `claude` with CLAUDE_CONFIG_DIR set to the profile dir.
# Uses a fake `claude` on PATH that prints the env var it received.
[windows] skip

chmod 0777 bin/claude
env PATH=$WORK/bin:$PATH

exec claudectx add personal
exec claudectx use personal
stdout 'FAKE CLAUDE'
stdout 'CLAUDE_CONFIG_DIR='
stdout 'profiles/personal'

# Extra args after the name are forwarded to claude.
exec claudectx use personal -- --hello world
stdout 'args: --hello world'

# Per-profile env (claudectx.env) is loaded into the claude process at launch.
cp envfile $XDG_CONFIG_HOME/claudectx/profiles/personal/claudectx.env
exec claudectx use personal
stdout 'VERTEX=on'
stdout 'REGION=us-east5'

# The hidden _exec-claude helper (used by the shell `claude` wrapper) applies the
# same env given an already-resolved dir.
exec claudectx _exec-claude $XDG_CONFIG_HOME/claudectx/profiles/personal --resume
stdout 'VERTEX=on'
stdout 'args: --resume'

-- bin/claude --
#!/bin/sh
echo "FAKE CLAUDE CLAUDE_CONFIG_DIR=$CLAUDE_CONFIG_DIR"
echo "VERTEX=$CLAUDE_CODE_USE_VERTEX REGION=$CLOUD_ML_REGION"
echo "args: $@"
-- envfile --
# work account
CLAUDE_CODE_USE_VERTEX=on
CLOUD_ML_REGION=us-east5
