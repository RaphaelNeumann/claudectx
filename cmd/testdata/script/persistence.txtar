# Default profile vs. per-terminal session profile.
[windows] skip

exec claudectx add personal
exec claudectx add work

# `set default` persists the default profile.
exec claudectx set default personal
stdout 'default profile set to "personal"'
exec claudectx current
stdout 'default profile: personal'
stdout 'this terminal:   \(following the default\)'

# the shell-init `claude` wrapper resolves the default via _current-dir.
exec claudectx _current-dir
stdout 'profiles/personal'

# raw `claudectx <name>` (no shell function) only hints; it does NOT change the default.
exec claudectx work
stdout 'To switch this terminal'
stdout 'claudectx use work'
exec claudectx current
stdout 'default profile: personal'

# setting an unknown default errors.
! exec claudectx set default ghost
stderr 'does not exist'

# `_profile-dir` resolves a profile to its dir (used by the shell function).
exec claudectx _profile-dir work
stdout 'profiles/work'

# a per-terminal override (CLAUDE_CONFIG_DIR) is reported as this terminal's profile.
env CLAUDE_CONFIG_DIR=$WORK/xdg/claudectx/profiles/work
exec claudectx current
stdout 'default profile: personal'
stdout 'this terminal:   work'
